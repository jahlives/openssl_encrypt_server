# PostgreSQL Configuration
POSTGRES_USER=openssl_server
POSTGRES_PASSWORD=test_password_secure_123456
POSTGRES_DB=openssl_encrypt
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
DEBUG=true
LOG_LEVEL=INFO

# Authentication Secrets (MUST be different from each other!)
KEYSERVER_TOKEN_SECRET=keyserver-secret-for-testing-min-32-characters-long
TELEMETRY_TOKEN_SECRET=telemetry-secret-for-testing-min-32-characters-long

# Module Enable Flags
KEYSERVER_ENABLED=true
TELEMETRY_ENABLED=true

# CORS Configuration
CORS_ORIGINS=*
