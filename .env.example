# PostgreSQL Configuration
POSTGRES_USER=openssl_server
# REQUIRED: Set a strong, unique password
POSTGRES_PASSWORD=
POSTGRES_DB=openssl_encrypt
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Alternative: Direct DATABASE_URL (overrides POSTGRES_* if set)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
DEBUG=false
LOG_LEVEL=INFO

# Authentication Secrets (MUST be different from each other!)
# Each secret must be at least 32 characters long
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
KEYSERVER_TOKEN_SECRET=
TELEMETRY_TOKEN_SECRET=

# Module Enable Flags
KEYSERVER_ENABLED=true
TELEMETRY_ENABLED=true
PEPPER_ENABLED=false
INTEGRITY_ENABLED=false

# Pepper Module Configuration
# SECURITY: Requires client certificates signed by YOUR self-signed CA (not public CAs)
# See docs/MTLS_SETUP.md and scripts/README.md for certificate setup
# Authentication mode: "proxy" (Nginx terminates mTLS) or "mtls" (direct TLS on port 8444)
PEPPER_AUTH_MODE=proxy

# Pepper TOTP Secret Key (Fernet key for encrypting TOTP secrets at rest)
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# REQUIRED if PEPPER_ENABLED=true
PEPPER_TOTP_SECRET_KEY=

# Pepper Deadman Switch
PEPPER_DEADMAN_ENABLED=true

# Pepper mTLS Configuration (only used if PEPPER_AUTH_MODE=mtls)
# Generate server cert with: scripts/create_client_cert.sh server
# CLIENT_CA must be YOUR self-signed CA certificate (from scripts/setup_ca.sh)
PEPPER_MTLS_PORT=8444
PEPPER_MTLS_CERT=/certs/server.crt
PEPPER_MTLS_KEY=/certs/server.key
PEPPER_MTLS_CLIENT_CA=/certs/ca.crt

# Integrity Module Configuration
# SECURITY: Requires client certificates signed by YOUR self-signed CA (not public CAs)
# See docs/MTLS_SETUP.md and scripts/README.md for certificate setup
# Integrity verification for encrypted file metadata
# Authentication mode: "proxy" (Nginx terminates mTLS) or "mtls" (direct TLS on port 8445)
INTEGRITY_AUTH_MODE=proxy

# Integrity mTLS Configuration (only used if INTEGRITY_AUTH_MODE=mtls)
# Generate server cert with: scripts/create_client_cert.sh server
# CLIENT_CA must be YOUR self-signed CA certificate (from scripts/setup_ca.sh)
INTEGRITY_MTLS_PORT=8445
INTEGRITY_MTLS_CERT=/certs/server.crt
INTEGRITY_MTLS_KEY=/certs/server.key
INTEGRITY_MTLS_CLIENT_CA=/certs/ca.crt

# Email-Confirmed Keyserver Registration
# When enabled, keyserver registration requires email confirmation
KEYSERVER_REQUIRE_EMAIL_VERIFICATION=false
# Base URL for building confirmation links (required if email verification enabled)
KEYSERVER_BASE_URL=

# SMTP Configuration (required if email verification enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_VERIFY_TLS=true
# SMTP_TLS_HOSTNAME=mail.example.com  # Override TLS hostname for LAN IP connections with valid domain certs
SMTP_FROM_ADDRESS=

# CORS Configuration
# For production, set to specific origins: https://example.com,https://app.example.com
# Empty = CORS disabled (secure default). Set specific origins for production:
CORS_ORIGINS=

# Rate Limiting (optional, for future implementation)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=60
