# PostgreSQL Configuration
POSTGRES_USER=openssl_server
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=openssl_encrypt
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Alternative: Direct DATABASE_URL (overrides POSTGRES_* if set)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
DEBUG=false
LOG_LEVEL=INFO

# Authentication Secrets (MUST be different from each other!)
# Each secret must be at least 32 characters long
KEYSERVER_TOKEN_SECRET=keyserver-secret-min-32-chars-CHANGE-ME-IN-PRODUCTION
TELEMETRY_TOKEN_SECRET=telemetry-secret-min-32-chars-CHANGE-ME-IN-PRODUCTION

# Module Enable Flags
KEYSERVER_ENABLED=true
TELEMETRY_ENABLED=true
PEPPER_ENABLED=false

# Pepper Module Configuration
# Authentication mode: "proxy" (Nginx terminates mTLS) or "mtls" (direct TLS on port 8444)
PEPPER_AUTH_MODE=proxy

# Pepper TOTP Secret Key (Fernet key for encrypting TOTP secrets at rest)
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# REQUIRED if PEPPER_ENABLED=true
PEPPER_TOTP_SECRET_KEY=

# Pepper Deadman Switch
PEPPER_DEADMAN_ENABLED=true

# Pepper mTLS Configuration (only used if PEPPER_AUTH_MODE=mtls)
PEPPER_MTLS_PORT=8444
PEPPER_MTLS_CERT=/certs/pepper-server.crt
PEPPER_MTLS_KEY=/certs/pepper-server.key
PEPPER_MTLS_CLIENT_CA=/certs/client-ca.crt

# CORS Configuration
# For production, set to specific origins: https://example.com,https://app.example.com
CORS_ORIGINS=*

# Rate Limiting (optional, for future implementation)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=60
